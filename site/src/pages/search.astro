---
import BaseLayout from "../layouts/BaseLayout.astro";
import { collections, siteData } from "../utils/data";

const navItems = [
  { href: "/", label: "Overview" },
  { href: "/collections/artifact-type/", label: "Collections" }
];
const artifactTypes = Object.keys(collections.artifactTypes).sort((left, right) => left.localeCompare(right));
const statuses = Object.keys(collections.statuses).sort((left, right) => left.localeCompare(right));
---

<BaseLayout title={`Search | ${siteData.site.title}`} description="Full-text research search" site={siteData.site} navItems={navItems}>
  <section class="page-intro">
    <p class="site-kicker">Search</p>
    <h1>Find research quickly</h1>
    <p>Search is client-side. The content pages remain readable with JavaScript disabled.</p>
  </section>
  <section class="search-shell">
    <form id="search-form" class="search-form">
      <label>
        <span>Query</span>
        <input id="search-query" name="q" type="search" placeholder="Search title, body, and summaries" />
      </label>
      <label>
        <span>Artifact type</span>
        <select id="search-artifactType">
          <option value="">All</option>
          {artifactTypes.map((value) => <option value={value}>{value}</option>)}
        </select>
      </label>
      <label>
        <span>Status</span>
        <select id="search-status">
          <option value="">All</option>
          {statuses.map((value) => <option value={value}>{value}</option>)}
        </select>
      </label>
      <button class="button" type="submit">Search</button>
    </form>
    <p id="search-status-line" aria-live="polite"></p>
    <div id="search-results" class="search-results"></div>
  </section>

  <script is:inline define:vars={{ baseUrl: siteData.site.baseUrl || "/" }}>
    const form = document.getElementById("search-form");
    const resultsRoot = document.getElementById("search-results");
    const statusLine = document.getElementById("search-status-line");

    function withBasePath(targetPath) {
      if (!targetPath || targetPath.startsWith("#")) {
        return targetPath;
      }
      if (/^(?:[a-z]+:)?\/\//i.test(targetPath)) {
        return targetPath;
      }
      const normalizedBase = !baseUrl || baseUrl === "/"
        ? "/"
        : (baseUrl.startsWith("/") ? baseUrl : `/${baseUrl}`).replace(/\/?$/, "/");
      const trimmedTarget = targetPath.replace(/^\/+/, "");
      return normalizedBase === "/" ? `/${trimmedTarget}` : `${normalizedBase}${trimmedTarget}`;
    }

    async function runSearch(query, artifactType, status) {
      const pagefind = await import(withBasePath("/pagefind/pagefind.js"));
      const search = await pagefind.search(query || "");
      const data = await Promise.all(search.results.map((result) => result.data()));
      return data.filter((item) => {
        if (artifactType && item.meta.artifactType !== artifactType) {
          return false;
        }
        if (status && item.meta.status !== status) {
          return false;
        }
        return true;
      });
    }

    function renderResults(items) {
      if (items.length === 0) {
        resultsRoot.innerHTML = "<p>No results matched the current query and filters.</p>";
        return;
      }

      resultsRoot.innerHTML = items.map((item) => `
        <article class="document-card">
          <p class="eyebrow">${item.meta.artifactType || ""} ${item.meta.stableId ? `· ${item.meta.stableId}` : ""}</p>
          <h2><a href="${withBasePath(item.url)}">${item.meta.title || item.url}</a></h2>
          <p>${item.excerpt || item.meta.summary || ""}</p>
          <dl class="inline-meta">
            <div><dt>Area</dt><dd>${item.meta.researchArea || ""}</dd></div>
            <div><dt>Status</dt><dd>${item.meta.status || ""}</dd></div>
          </dl>
        </article>
      `).join("");
    }

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      const query = document.getElementById("search-query").value;
      const artifactType = document.getElementById("search-artifactType").value;
      const status = document.getElementById("search-status").value;
      statusLine.textContent = "Searching…";
      const items = await runSearch(query, artifactType, status);
      statusLine.textContent = `${items.length} result${items.length === 1 ? "" : "s"}`;
      renderResults(items);
    });
  </script>
</BaseLayout>
