---
import BaseLayout from "./BaseLayout.astro";
import { withBasePath } from "../utils/paths";

const { document, backlinks = [], related = [], site } = Astro.props;
const pageTitle = `${document.title} | ${site.title}`;
const navItems = [
  { href: "/", label: "Overview" },
  { href: "/search/", label: "Search" },
  { href: "/collections/artifact-type/", label: "Collections" }
];
---

<BaseLayout title={pageTitle} description={document.summary || site.description} site={site} navItems={navItems}>
  <article class="document-shell" data-pagefind-body>
    <header class="document-header">
      <p class="eyebrow">
        <span data-pagefind-meta="artifactType">{document.artifactType}</span>
        {document.id && <span data-pagefind-meta="stableId">{document.id}</span>}
      </p>
      <h1 data-pagefind-meta="title">{document.title}</h1>
      {document.summary && <p class="lede" data-pagefind-meta="summary">{document.summary}</p>}
      <dl class="metadata-panel">
        {document.id && <div><dt>Identifier</dt><dd>{document.id}</dd></div>}
        <div><dt>Research Area</dt><dd data-pagefind-meta="researchArea">{document.researchArea}</dd></div>
        {document.discipline?.length > 0 && <div><dt>Discipline</dt><dd data-pagefind-meta="discipline">{document.discipline.join(", ")}</dd></div>}
        <div><dt>Status</dt><dd data-pagefind-meta="status">{document.status}</dd></div>
        {document.version && <div><dt>Version</dt><dd>{document.version}</dd></div>}
        {document.confidence != null && <div><dt>Confidence</dt><dd>{document.confidence}</dd></div>}
        {document.completion != null && <div><dt>Completion</dt><dd>{document.completion}</dd></div>}
        {document.priority && <div><dt>Priority</dt><dd>{document.priority}</dd></div>}
        {document.tags?.length > 0 && <div><dt>Tags</dt><dd data-pagefind-meta="tags">{document.tags.join(", ")}</dd></div>}
        {document.updated && <div><dt>Updated</dt><dd>{document.updated}</dd></div>}
        <div><dt>Source</dt><dd>{document.sourcePath}</dd></div>
      </dl>
    </header>

    {document.headings?.length > 1 && (
      <aside class="toc-panel">
        <h2>Contents</h2>
        <ol>
          {document.headings.filter((heading) => heading.depth <= 3).map((heading) => (
            <li><a href={`#${heading.text.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`}>{heading.text}</a></li>
          ))}
        </ol>
      </aside>
    )}

    <section class="document-body" set:html={document.html} />

    {(related.length > 0 || backlinks.length > 0) && (
      <section class="relationship-grid">
        {related.length > 0 && (
          <section>
            <h2>Related Documents</h2>
            <ul>
              {related.map((item) => <li><a href={withBasePath(site.baseUrl, item.url)}>{item.title}</a></li>)}
            </ul>
          </section>
        )}
        {backlinks.length > 0 && (
          <section>
            <h2>Backlinks</h2>
            <ul>
              {backlinks.map((item) => <li><a href={withBasePath(site.baseUrl, item.url)}>{item.title}</a></li>)}
            </ul>
          </section>
        )}
      </section>
    )}
  </article>
</BaseLayout>
