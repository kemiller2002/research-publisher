{
  "name": "research-publisher",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "research-publisher": "./src/cli/index.mjs"
  },
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "src",
    "site/src",
    "site/astro.config.mjs",
    "site/package.json",
    "README.md"
  ],
  "engines": {
    "node": ">=24 <26"
  },
  "scripts": {
    "dev": "npm run research:dev",
    "build": "npm run research:build",
    "test": "npm run research:test",
    "research:dev": "node ./src/cli/index.mjs dev --config ./research-publisher.config.mjs",
    "research:build": "node ./src/cli/index.mjs build --config ./research-publisher.config.mjs",
    "research:validate": "node ./src/cli/index.mjs validate --config ./research-publisher.config.mjs",
    "research:test": "vitest run",
    "research:clean": "node ./src/cli/index.mjs clean --config ./research-publisher.config.mjs",
    "research:inventory": "node ./src/cli/index.mjs inventory --config ./research-publisher.config.mjs",
    "research:check-links": "node ./src/cli/index.mjs check-links --config ./research-publisher.config.mjs",
    "research:preview": "node ./src/cli/index.mjs preview --config ./research-publisher.config.mjs",
    "research:migrate": "node ./src/cli/index.mjs migrate --config ./research-publisher.config.mjs",
    "research:build:fixture": "node ./src/cli/index.mjs build --config ./fixtures/alt-research/research-publisher.config.mjs",
    "smoke:consumer": "node ./scripts/smoke-consumer.mjs"
  },
  "dependencies": {
    "astro": "^5.12.8",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "pagefind": "^1.3.0",
    "rehype-sanitize": "^6.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "unist-util-visit": "^5.0.0",
    "yaml": "^2.8.1",
    "zod": "^4.0.14"
  },
  "devDependencies": {
    "vitest": "^3.2.4"
  }
}
